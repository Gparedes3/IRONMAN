# ===== Configuración de IRONMAN =====
# Copia este archivo a ".env" y rellena tus datos reales.
# El archivo .env NO se sube a git (está en .gitignore).

# --- Correo (Gmail vía IMAP/SMTP) ---
# Genera una "contraseña de aplicación" aquí (necesitas verificación en 2 pasos activada):
#   https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=guillermouide@gmail.com
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
IMAP_HOST=imap.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Modelo de lenguaje (Ollama) ---
# Mejor equilibrio tamaño/velocidad/calidad según la Parte A del estudio
OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
OLLAMA_HOST=http://localhost:11434
